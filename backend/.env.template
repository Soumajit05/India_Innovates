# Environment Configuration for India_Innovates

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string for relational data
DATABASE_URL=postgresql://user:password@localhost:5432/india_innovates

# Neo4j graph database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ============================================================================
# LLM & REASONING
# ============================================================================

# Anthropic Claude API key
ANTHROPIC_API_KEY=your_anthropic_key

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT secret key (change in production!)
JWT_SECRET_KEY=your-super-secret-key-change-in-production-2024

# JWT algorithm
JWT_ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API keys for legacy authentication (comma-separated)
VALID_API_KEYS=key1,key2,key3

# ============================================================================
# DATA SOURCES - TWITTER/X
# ============================================================================

# Twitter API v2 authentication
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# ============================================================================
# EMBEDDINGS & SEMANTIC SEARCH
# ============================================================================

# HuggingFace model for embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================================
# INGESTION CONFIGURATION
# ============================================================================

# GDELT API ingestion interval (minutes)
GDELT_INGESTION_INTERVAL=15

# RSS feed ingestion interval (minutes)
RSS_INGESTION_INTERVAL=15

# Twitter streaming interval (minutes)
TWITTER_INGESTION_INTERVAL=15

# Horizon for data ingestion (hours back)
INGESTION_LOOKBACK_HOURS=24

# ============================================================================
# GRAPH CONFIGURATION
# ============================================================================

# Graph edge decay rate (annual, 0-1)
GRAPH_DECAY_RATE=0.1

# Edge strength threshold for dashboard alerts
EDGE_STRENGTH_THRESHOLD=0.65

# Temporal trend analysis window (days)
TEMPORAL_WINDOW_DAYS=7

# ============================================================================
# MISCELLANEOUS
# ============================================================================

# Debug mode (enable logging, etc.)
DEBUG=false

# Log level
LOG_LEVEL=INFO

# App port
PORT=8000

# CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Timezone
TZ=UTC
